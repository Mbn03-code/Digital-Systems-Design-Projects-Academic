module xnor_gate #(parameter N = 1) (
    input  wire [N-1:0] a,
    input  wire [N-1:0] b,
    output wire [N-1:0] xnor_out
);

    wire [N-1:0] xor_res;

    xor #(N) xor_inst (
        .a(a),
        .b(b),
        .xor_out(xor_res)
    );

    not #(N) not_inst (
        .a(xor_res),
        .not_out(xnor_out)
    );

endmodule
