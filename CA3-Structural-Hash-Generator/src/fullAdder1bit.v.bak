module fulladder1bit (
    input  wire a,
    input  wire b,
    input  wire cin,
    output wire sum,
    output wire cout
);

    wire s1, c1, c2;

    xor_gate u1 (.a(a),   .b(b),   .xor_out(s1));
    xor_gate u2 (.a(s1),  .b(cin), .xor_out(sum));

    and_gate u3 (.a(s1),  .b(cin), .and_out(c1));
    and_gate u4 (.a(a),  .b(b), .and_out(c2));

    or_gate u5 (.a(c1),  .b(c2),  .or_out(cout));

endmodule

//---------------------
`timescale 1ns/1ps

module test_fulladder1bit;

    reg  a, b, cin;
    wire sum, cout;

    fulladder1bit dut (
        .a(a),
        .b(b),
        .cin(cin),
        .sum(sum),
        .cout(cout)
    );

    initial begin
        $display("---- TEST fulladder1bit (3 cases) ----");

        // 1 + 1
        a = 1; b = 1; cin = 0;
        #1;
        $display("1 + 1 = sum=%b cout=%b", sum, cout);

        // 1 + 0
        a = 1; b = 0; cin = 0;
        #1;
        $display("1 + 0 = sum=%b cout=%b", sum, cout);

        // 0 + 0
        a = 0; b = 0; cin = 0;
        #1;
        $display("0 + 0 = sum=%b cout
