module GH_controller(
    input  wire clk,
    input  wire reset,
    input  wire start,
    input  wire prng_done,
    input  wire count_done,

    output wire start_prng,
    output wire stage_load,
    output wire load_init,
    output wire count_enable,
    output wire done
);

    wire state0, state1, state2, state3; // SIDLE, SLOAD_INIT, SPRNG, SCHECKDONE

    
    wire d0;

    // SIDLE --d0 = (~start & state0) | (flag)
    wire nstart, s0_and_nstart;
    not_gate not1 (.a(start), .not_out(nstart));
    and_gate #(1) and0 (.a({state0}), .b({nstart}), .and_out(s0_and_nstart));
    wire d0S;


    // SPRNG --d2 = state1 | (state2 & ~prng_done & ~count_done)|state3

    wire nprng, ncount, s2_and_nprng , or_state;
    not_gate not2 (.a(prng_done), .not_out(nprng));
    not_gate not3 (.a(count_done), .not_out(ncount));
    and_gate #(1) and3 (.a({state2}), .b({nprng}), .and_out(s2_and_nprng));
    or_gate #(1) or1 (.a({state1}), .b({state3}), .or_out(or_state));
    
    wire flag;
    wire s3_and_flag;
    and_gate #(1) and5 (.a({state3}), .b({flag}), .and_out(s3_and_flag));

    or_gate  #(1) or0  (.a({s0_and_nstart}), .b({s3_and_flag}), .or_out(d0));
    mux2 sel_d0(.a(d0) ,.b(1'b1) ,.sel(reset) ,.out(d0S));


    s2 ff0 (.D00(1'b0), .D01(1'b1), .D10(1'b1), .D11(1'b1),
            .A1(d0S), .B1(d0S), .A0(reset), .B0(reset),
            .clr(1'b0), .clk(clk), .out(state0));

    // SLOAD_INIT = state0 & start
    s2 ff1 (.D00(1'b0), .D01(1'b1), .D10(1'b0), .D11(1'b0),
            .A1(1'b0), .B1(1'b0), .A0(state0), .B0(start),
            .clr(reset), .clk(clk), .out(state1));


    s2 ff2 (.D00(1'b0), .D01(1'b0), .D10(1'b1), .D11(1'b0),
            .A1(s2_and_nprng), .B1(or_state), .A0(1'b0), .B0(1'b0),
            .clr(reset), .clk(clk), .out(state2));
    
    // SCHECKDONE d3 = state2 & prng_done
    s2 ff3 (.D00(1'b0), .D01(1'b1), .D10(1'b0), .D11(1'b1),
            .A1(1'b0), .B1(1'b0), .A0(state2), .B0(prng_done),
            .clr(reset), .clk(clk), .out(state3));

    s2 ffflag (.D00(flag), .D01(1'b1), .D10(1'b0), .D11(1'b0),
            .A1(state0), .B1(1'b0), .A0(state2), .B0(count_done),
            .clr(reset), .clk(clk), .out(flag));

    
    
    assign start_prng = state2;

    assign load_init = state1;

    assign count_enable = state3;

    assign stage_load = state3;


    wire s0_and_c;
    and_gate #(1) and0 (.a({state0}), .b({count_done}), .and_out(s0_and_c));
    assign done = s0_and_c;

endmodule


module GH_controller_tb;
    reg clk, reset, start, prng_done, count_done;
    wire start_prng, stage_load, load_init, count_enable, done;

    GH_controller uut (
        .clk(clk),
        .reset(reset),
        .start(start),
        .prng_done(prng_done),
        .count_done(count_done),
        .start_prng(start_prng),
        .stage_load(stage_load),
        .load_init(load_init),
        .count_enable(count_enable),
        .done(done)
    );

    initial clk = 0;
    always #5 clk = ~clk;

    initial begin

        reset = 1; start = 0; prng_done = 0; count_done = 0; #10;
        reset = 0; start = 1; #10;
        start = 0; prng_done = 1; #300;
        count_done = 1; #100;
        start = 1; prng_done = 0; count_done = 0; #300;
        start = 0; prng_done = 1; count_done = 1; #300;

        $finish;
    end
endmodule
