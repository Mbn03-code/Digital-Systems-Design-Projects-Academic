module PRNG_controller(
    input  wire clk,
    input  wire reset,
    input  wire start,
    input  wire count_done,
    output wire load_reg,
    output wire count_enable
);

    wire [3:0] st;
    wire n_start;
    wire n_count_done;

    // NOT
    not_gate #(1) NOT_COUNT_DONE (.a(count_done), .not_out(n_count_done));
    not_gate #(1) NOT_START      (.a(start),      .not_out(n_start));

    // -------------------------
    // helper: any_state = OR of all one-hot bits
    // if none active => we want to force IDLE_next = 1 (recovery from all-zero)
    // -------------------------
    wire any_state;
    or_gate #(1) OR_S0S1 (.a(st[0]), .b(st[1]), .or_out(any_state));    // temp: s0 | s1
    wire any_state_hi;
    or_gate #(1) OR_S2S3 (.a(st[2]), .b(st[3]), .or_out(any_state_hi)); // temp: s2 | s3
    wire any_state_all;
    or_gate #(1) OR_ANY  (.a(any_state), .b(any_state_hi), .or_out(any_state_all));
    wire none_active;
    not_gate #(1) NOT_ANY (.a(any_state_all), .not_out(none_active)); // none_active = ~any_state_all

    // --------------------------------------------
    // IDLE_next = none_active OR (IDLE & !start) OR (DONE & !start)
    // (اضافه کردن none_active باعث میشه بعد از reset یا اگر اشتباهاً همه صفر شدیم،
    //  وارد IDLE بشیم)
    // --------------------------------------------
    wire idle_and_nstart;
    wire done_and_nstart;
    and_gate #(1) AND_IDLE_NSTART (.a(st[0]), .b(n_start), .and_out(idle_and_nstart));
    and_gate #(1) AND_DONE_NSTART (.a(st[3]), .b(n_start), .and_out(done_and_nstart));

    wire IDLE_part;
    or_gate  #(1) OR_IDLE_PART (.a(idle_and_nstart), .b(done_and_nstart), .or_out(IDLE_part));

    wire IDLE_next;
    or_gate  #(1) OR_IDLE_FINAL (.a(none_active), .b(IDLE_part), .or_out(IDLE_next));
    // --------------------------------------------

    // --------------------------------------------
    // LOAD_next = IDLE & start
    // --------------------------------------------
    wire LOAD_next;
    and_gate #(1) AND_LOAD (.a(st[0]), .b(start), .and_out(LOAD_next));

    // --------------------------------------------
    // SHIFT_next = LOAD OR (SHIFT & !count_done)
    // --------------------------------------------
    wire shift_and_ncd;
    and_gate #(1) AND_SHIFT_NCD (.a(st[2]), .b(n_count_done), .and_out(shift_and_ncd));

    wire SHIFT_next;
    or_gate  #(1) OR_SHIFT (.a(st[1]), .b(shift_and_ncd), .or_out(SHIFT_next));

    // --------------------------------------------
    // DONE_next = (SHIFT & count_done) OR (DONE & start)
    // --------------------------------------------
    and_gate #(1) AND_SHIFT_CD (.a(st[2]), .b(count_done), .and_out(DONE_next));

    wire DONE_next;

    // --------------------------------------------
    // S2 registers (one-hot). نگه‌داشتم نام D0..D3 همون‌جوری بمونه.
    // هر S2 طوری وصل شده که D0 حامل مقدار next برای اون بیت باشه.
    // سلکت‌ها را صفر گذاشتیم تا همیشه D0 انتخاب شود (S2 مثل D-FF عمل کند).
    // --------------------------------------------

    S2  FF_IDLE (
        .D0(IDLE_next), .D1(1'b0), .D2(1'b0), .D3(1'b0),
        .A1(1'b0), .B1(1'b0), .A0(1'b0), .B0(1'b0),
        .clr(reset), .clk(clk), .out(st[0])
    );

    S2  FF_LOAD (
        .D0(LOAD_next), .D1(1'b0), .D2(1'b0), .D3(1'b0),
        .A1(1'b0), .B1(1'b0), .A0(1'b0), .B0(1'b0),
        .clr(reset), .clk(clk), .out(st[1])
    );

    S2  FF_SHIFT (
        .D0(SHIFT_next), .D1(1'b0), .D2(1'b0), .D3(1'b0),
        .A1(1'b0), .B1(1'b0), .A0(1'b0), .B0(1'b0),
        .clr(reset), .clk(clk), .out(st[2])
    );

    S2  FF_DONE (
        .D0(DONE_next), .D1(1'b0), .D2(1'b0), .D3(1'b0),
        .A1(1'b0), .B1(1'b0), .A0(1'b0), .B0(1'b0),
        .clr(reset), .clk(clk), .out(st[3])
    );

    // خروجی‌ها
    assign load_reg     = st[1];      // LOAD state
    assign count_enable = st[2];      // SHIFT state

endmodule
